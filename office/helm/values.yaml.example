# Copy to values.yaml and customize (values.yaml is gitignored)
#
#   cp office/helm/values.yaml.example office/helm/values.yaml

fullnameOverride: rmf-office-demo

app:
  name: openrmf-office-demo

namespace:
  name: rmf-demos

image:
  # Full Quay.io reference (built with common/build-and-push.sh)
  fullRef: quay.io/your-org/openrmf-openshift-office-demo:certified
  pullPolicy: Always

# Optional — for private Quay repositories
pullSecret:
  name: ""  # e.g. quay-pull-secret

serviceAccount:
  create: true
  name: rmf-demo

demo:
  name: office
  launchFile: office.launch.xml

# Robot-as-individual-pod architecture configuration
# When enabled, each robot runs as a separate Kubernetes pod with its own fleet adapter.
# The simulation pod runs world-only (no fleet adapter).
robots:
  enabled: false  # Set to true to enable robot-as-pod architecture
  fleet_name: "tinyRobot"
  instances:
    - name: tinyRobot1
    - name: tinyRobot2
  resources:
    requests:
      cpu: "1"
      memory: "2Gi"
    limits:
      cpu: "2"
      memory: "4Gi"

dispatch:
  command: /opt/rmf/demos/office/scripts/dispatch-task.sh
  readyWaitSeconds: 30
  robotMode:
    enabled: true
    command: /opt/rmf/demos/office/scripts/dispatch-task-robot-mode.sh
    readyWaitSeconds: 60

# RMF Web — 2D dashboard (map, robots, tasks) via OpenShift Routes
rmfWeb:
  enabled: true
  serverUri: ws://rmf-office-demo-api:80/_internal
  apiServer:
    image: quay.io/your-org/openrmf-rmf-web-zenoh:latest
    pullPolicy: Always
    rmwImplementation: rmw_zenoh_cpp
    resources:
      requests:
        cpu: 250m
        memory: 512Mi
      limits:
        cpu: "1"
        memory: 1Gi
  dashboard:
    image: ghcr.io/open-rmf/rmf-web/demo-dashboard:jazzy-nightly
    nginxImage: nginxinc/nginx-unprivileged:alpine
    pullPolicy: IfNotPresent
    resources:
      requests:
        cpu: 100m
        memory: 256Mi
      limits:
        cpu: 500m
        memory: 512Mi
  # Option A: OpenShift Routes (public access)
  routes:
    enabled: false
    clusterDomain: apps.example.openshift.com
    dashboardHost: ""
    apiHost: ""
    trajectoryHost: ""
  # Option B: oc port-forward (local-only access, when routes.enabled=false)
  #   Run: ./office/port-forward.sh <namespace>
  portForward:
    dashboardPort: "3000"

# noVNC — stream Gazebo/RViz virtual desktop to browser
novnc:
  enabled: true
  image: quay.io/your-org/openrmf-openshift-office-demo:novnc
  pullPolicy: Always
  vncPort: 5900
  webPort: 8080
  displayWidth: 1280
  displayHeight: 720
  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 500m
      memory: 256Mi
  routes:
    enabled: false
    clusterDomain: apps.example.openshift.com
    novncHost: ""

# Zenoh Router — central message broker (replaces DDS)
zenoh:
  enabled: true
  image: quay.io/your-org/openrmf-zenoh-router:latest
  pullPolicy: Always
  port: 7447
  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 250m
      memory: 256Mi

shm:
  sizeLimit: 64Mi

resources:
  simulation:
    requests:
      cpu: "2"
      memory: 4Gi
    limits:
      cpu: "4"
      memory: 8Gi
  # Used when novnc.enabled — Gazebo GUI + RViz need more CPU/RAM
  simulationViz:
    requests:
      cpu: "3"
      memory: 6Gi
    limits:
      cpu: "6"
      memory: 10Gi
  fleetMonitor:
    requests:
      cpu: 250m
      memory: 512Mi
    limits:
      cpu: "1"
      memory: 1Gi
  taskDispatch:
    requests:
      cpu: 250m
      memory: 512Mi
    limits:
      cpu: "1"
      memory: 1Gi
  # When robots.enabled=true, simulation becomes world-only with reduced resources
  simulationWorldOnly:
    requests:
      cpu: "1"
      memory: 2Gi
    limits:
      cpu: "2"
      memory: 4Gi
  simulationWorldOnlyViz:
    requests:
      cpu: "2"
      memory: 3Gi
    limits:
      cpu: "3"
      memory: 5Gi
