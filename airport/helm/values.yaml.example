# Copy to values.yaml and customize (values.yaml is gitignored)
#
#   cp airport/helm/values.yaml.example airport/helm/values.yaml

fullnameOverride: rmf-airport-demo

app:
  name: openrmf-airport-demo

namespace:
  name: rmf-demos

image:
  fullRef: quay.io/your-org/rmf-humble:certified
  pullPolicy: Always

pullSecret:
  name: ""

serviceAccount:
  create: false  # reuse rmf-demo from office or common deploy
  name: rmf-demo

demo:
  name: airport
  launchFile: airport.launch.xml

dispatch:
  command: /opt/rmf/demos/airport/scripts/dispatch-task.sh
  readyWaitSeconds: 60

# Optional — shared library from common/helm/openrmf-lib (add Chart.yaml dependency)
rmfWeb:
  enabled: false
  serverUri: ws://localhost:8000/_internal
  routes:
    clusterDomain: apps.example.openshift.com

novnc:
  enabled: false
  routes:
    clusterDomain: apps.example.openshift.com

shm:
  sizeLimit: 2Gi

resources:
  simulation:
    requests:
      cpu: "2"
      memory: 4Gi
    limits:
      cpu: "4"
      memory: 8Gi
  fleetMonitor:
    requests:
      cpu: 250m
      memory: 512Mi
    limits:
      cpu: "1"
      memory: 1Gi
  taskDispatch:
    requests:
      cpu: 250m
      memory: 512Mi
    limits:
      cpu: "1"
      memory: 1Gi
