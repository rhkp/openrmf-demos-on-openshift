# Copy to values.yaml and customize (values.yaml is gitignored)
#
#   cp hotel/helm/values.yaml.example hotel/helm/values.yaml

fullnameOverride: rmf-hotel-demo

app:
  name: openrmf-hotel-demo

namespace:
  name: rmf-demos

image:
  fullRef: quay.io/your-org/openrmf-openshift-hotel-demo:certified
  pullPolicy: Always

pullSecret:
  name: ""

serviceAccount:
  create: false
  name: rmf-demo

demo:
  name: hotel
  launchFile: hotel.launch.xml

dispatch:
  command: /opt/rmf/demos/hotel/scripts/dispatch-task.sh
  startupWaitSeconds: 30
  readyWaitSeconds: 90

rmfWeb:
  enabled: true
  serverUri: ws://localhost:8000/_internal
  apiServer:
    image: ghcr.io/open-rmf/rmf-web/api-server:jazzy-nightly
    pullPolicy: IfNotPresent
    rmwImplementation: rmw_cyclonedds_cpp
    resources:
      requests:
        cpu: 250m
        memory: 512Mi
      limits:
        cpu: "1"
        memory: 1Gi
  dashboard:
    image: ghcr.io/open-rmf/rmf-web/demo-dashboard:jazzy-nightly
    nginxImage: nginxinc/nginx-unprivileged:alpine
    pullPolicy: IfNotPresent
    resources:
      requests:
        cpu: 100m
        memory: 256Mi
      limits:
        cpu: 500m
        memory: 512Mi
  routes:
    enabled: false
    clusterDomain: apps.example.openshift.com
    dashboardHost: ""
    apiHost: ""
    trajectoryHost: ""

novnc:
  enabled: true
  image: quay.io/your-org/openrmf-openshift-hotel-demo:novnc
  pullPolicy: Always
  vncPort: 5900
  webPort: 8080
  displayWidth: 1280
  displayHeight: 720
  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 500m
      memory: 256Mi
  routes:
    enabled: false
    clusterDomain: apps.example.openshift.com
    novncHost: ""

shm:
  sizeLimit: 4Gi

resources:
  simulation:
    requests:
      cpu: "3"
      memory: 6Gi
    limits:
      cpu: "6"
      memory: 10Gi
  simulationViz:
    requests:
      cpu: "4"
      memory: 8Gi
    limits:
      cpu: "8"
      memory: 12Gi
  fleetMonitor:
    requests:
      cpu: 250m
      memory: 512Mi
    limits:
      cpu: "1"
      memory: 1Gi
  taskDispatch:
    requests:
      cpu: 250m
      memory: 512Mi
    limits:
      cpu: "1"
      memory: 1Gi
